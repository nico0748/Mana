# ============================================================
# 本番環境変数テンプレート
# cp .env.prod.example .env.prod して値を設定してください
# .env.prod は絶対に Git にコミットしないこと！
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=doujin_pp
POSTGRES_USER=doujin
# 強力なパスワードを設定（例: openssl rand -base64 32 で生成）
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Prisma が使う接続文字列（POSTGRES_* と合わせること）
DATABASE_URL=postgresql://doujin:CHANGE_THIS_STRONG_PASSWORD@db:5432/doujin_pp

# ── Backend ─────────────────────────────────────────────────
PORT=3000
# 自分のドメインに変更（末尾スラッシュなし）
CORS_ORIGIN=https://yourdomain.com
